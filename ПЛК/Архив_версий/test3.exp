

(* @NESTEDCOMMENTS := 'Yes' *)
(* @PATH := '' *)
(* @OBJECTFLAGS := '0, 8' *)
(* @SYMFILEFLAGS := '2048' *)
PROGRAM PLC_PRG
VAR
    (* Control Inputs *)
    prev_d5 : BOOL := TRUE;  (* Edge detection for Manual/Auto switch *)
    enableStart : BOOL;      (* Manual Mode (TRUE) / Auto Mode (FALSE) *)
    
    (* Pedals *)
    btnD7 : BOOL;            (* Forward *)
    btnD8 : BOOL;            (* Backward *)
    both : BOOL;             (* Both pressed *)
    
    prev_d7 : BOOL := FALSE;
    prev_d8 : BOOL := FALSE;
    prev_both : BOOL := FALSE;

    (* Encoder *)
    encAEdge : R_TRIG;
    encBEdge : R_TRIG;

    (* Process State *)
    done : BOOL := FALSE;    (* Target reached flag *)
    
    (* Timers & Triggers *)
    targetPulseTrigger : BOOL := FALSE;
    tpTarget : TP;           (* Done Pulse *)
    
    beepTargetTrigger : BOOL := FALSE;
    tpBeepTarget : TP;       (* Done Beep *)

    (* Error Beep Logic *)
    errorBeepTrigger : BOOL := FALSE;
    tErrTotal : TON;
    tErrDelay1 : TON;
    tErrDelay2 : TON;
    tErrDelay3 : TON;
    rTrigErr1 : R_TRIG;
    rTrigErr2 : R_TRIG;
    rTrigErr3 : R_TRIG;
    tpErr : TP;

    (* Modbus / Web control *)
    prev_mb_in_command : WORD := 0;
    prev_mb_in_WebTarget : WORD := 0;
    init_done : BOOL := FALSE;
    
    (* Helper for Modbus Output Mapping *)
    (* Ensure global vars are assigned to outputs if mapped there *)
END_VAR
(* @END_DECLARATION := '0' *)
(* 1. Input Mapping *)
enableStart := gDI_5;
btnD7 := gDI_7;
btnD8 := gDI_8;
both := btnD7 AND btnD8;

(* 2. Encoder Processing *)
encAEdge(CLK := gEncoderA);
(* encBEdge(CLK := gEncoderB); Not typically needed for quadrature decoding if using A edge + B level *)

IF encAEdge.Q THEN
    IF gEncoderB THEN
        (* Direction depends on wiring, assuming B leads or lags *)
        (* Adjust +/- based on empirical test if counting wrong direction *)
        gEncoderCount := gEncoderCount + 1;
    ELSE
        gEncoderCount := gEncoderCount - 1;
    END_IF;
END_IF;

(* 3. Angle Calculation *)
IF gCalibCountsPerRev = 0 THEN gCalibCountsPerRev := 360; END_IF;
(* Negative sign to align physical direction with logical angle increases *)
gCurrentAngle := -1.0 * (DINT_TO_REAL(gEncoderCount) * 360.0 / DINT_TO_REAL(gCalibCountsPerRev));

(* 4. Mode Switching & Calibration *)
(* When switching from Manual (1) to Auto (0), resetting zero position *)
IF (prev_d5 AND NOT enableStart) THEN
    gEncoderCount := 0;
    gCurrentAngle := 0.0;
    gCycle := 1;
    gTargetAngle := gDefaultTarget;
    done := FALSE;
END_IF;
prev_d5 := enableStart;

(* 5. Modbus / Web Commands Processing *)

(* 5.1 Web Target Update *)
(* If WebTarget changes, update logical target *)
IF mb_in_WebTarget <> prev_mb_in_WebTarget THEN
    IF init_done THEN (* Avoid overwriting on startup if ESP is 0 *)
         gDefaultTarget := WORD_TO_REAL(mb_in_WebTarget) / 10.0;
         gTargetAngle := gDefaultTarget; 
         gCycle := 1;
         done := FALSE;
    ELSE
         (* Sync local previous value to current input on first scan to establish baseline *)
         (* If ESP sends 0 on startup, we ignore it as a 'change' for the logic, 
            presuming RETAIN gDefaultTarget is correct. *)
         NULL; 
    END_IF;
END_IF;
prev_mb_in_WebTarget := mb_in_WebTarget;
init_done := TRUE;

(* 5.2 Command Register *)
IF mb_in_Command <> 0 AND mb_in_Command <> prev_mb_in_command THEN
    CASE WORD_TO_INT(mb_in_Command) OF
        1: (* START *)
            IF NOT enableStart THEN 
                done := FALSE; 
                gCycle := 1; 
                gTargetAngle := gDefaultTarget;
            END_IF;
        2: (* STOP *)
            (* Just stops motors by logic below, setting done=TRUE effectively stops Auto moves *)
             (* But STOP usually means emergency stop. In Auto, we can set Done=TRUE to stop. *)
             done := TRUE;
        3: (* ZERO / CALIBRATE *)
            gEncoderCount := 0;
            gCurrentAngle := 0.0;
    END_CASE;
END_IF;
prev_mb_in_command := mb_in_Command;

(* 6. Cycle Logic (Auto Mode) *)
IF NOT enableStart AND NOT done THEN
    IF gCycle = 1 THEN
        gTargetAngle := gDefaultTarget;
    ELSIF gCycle = 2 THEN
        gTargetAngle := 0.0;
    END_IF;
END_IF;

(* 7. Output to Modbus (Mapping to Output Registers) *)
mb_out_DefaultTarget := REAL_TO_WORD(gDefaultTarget * 10.0);
mb_out_CurrentAngle  := REAL_TO_WORD(ABS(gCurrentAngle * 10.0));
mb_out_TargetAngle   := REAL_TO_WORD(gTargetAngle * 10.0);
mb_out_Cycle         := INT_TO_WORD(gCycle);

IF done THEN mb_out_Done := 1; ELSE mb_out_Done := 0; END_IF;
IF enableStart THEN mb_out_Mode := 1; ELSE mb_out_Mode := 0; END_IF;

mb_out_Pedals := 0;
IF btnD7 THEN mb_out_Pedals := mb_out_Pedals + 1; END_IF;
IF btnD8 THEN mb_out_Pedals := mb_out_Pedals + 2; END_IF;

(* 8. Motor Control Logic *)
(* gDO_10 = Forward, gDO_11 = Backward *)

IF enableStart THEN  (* MANUAL MODE *)
    IF both THEN
        gDO_10 := FALSE;
        gDO_11 := FALSE;
    ELSE
        gDO_10 := btnD7;
        gDO_11 := btnD8;
    END_IF;
ELSE  (* AUTO MODE *)
    (* Move Forward if: Pedal Fwd, Not Back, Angle < Target, Not Done *)
    gDO_10 := btnD7 AND NOT btnD8 AND NOT both AND (gCurrentAngle < gTargetAngle) AND NOT done;
    
    (* Move Backward if: Pedal Back, Not Fwd, Angle > 0, Not Done, Not Both *)
    gDO_11 := btnD8 AND NOT btnD7 AND NOT both AND (gCurrentAngle > 0.0) AND NOT done;
END_IF;

(* 9. Target Reached Check *)
IF NOT enableStart AND NOT done THEN
    IF ABS(gCurrentAngle - gTargetAngle) < 0.5 THEN
        done := TRUE;
        targetPulseTrigger := TRUE;
        beepTargetTrigger := TRUE;
        (* Switch Cycle for next move *)
        IF gCycle = 1 THEN gCycle := 2; ELSE gCycle := 1; END_IF;
    END_IF;
END_IF;

(* Re-enable movement if drift occurs? Or wait for next command? 
   TZ says: "If after this deviation exceeds 1 deg, done resets" *)
IF ABS(gCurrentAngle - gTargetAngle) > 1.0 THEN
    done := FALSE;
END_IF;

(* 10. Indication & Beeper *)

(* Target Pulse (DO_12) *)
tpTarget(IN := targetPulseTrigger, PT := T#500MS);
gDO_12 := tpTarget.Q;
IF tpTarget.Q THEN targetPulseTrigger := FALSE; END_IF;

(* Target Beep *)
tpBeepTarget(IN := beepTargetTrigger, PT := T#500MS);
IF tpBeepTarget.Q THEN beepTargetTrigger := FALSE; END_IF;

(* Error Conditions *)
IF NOT enableStart THEN
    (* Error: Forward pedal when already at/past target *)
    IF (btnD7 AND NOT prev_d7) AND (gCurrentAngle >= gDefaultTarget) AND (gCycle = 1) THEN
        errorBeepTrigger := TRUE;
    END_IF;
    (* Error: Back pedal when already at 0 *)
    IF (btnD8 AND NOT prev_d8) AND (gCurrentAngle <= 0.0) AND (gCycle = 2) THEN
        errorBeepTrigger := TRUE;
    END_IF;
    (* Error: Both pedals *)
    IF both AND NOT prev_both THEN
        errorBeepTrigger := TRUE;
    END_IF;
END_IF;

(* Error Beep Sequence (3 short beeps) *)
tErrTotal(IN := errorBeepTrigger, PT := T#1400MS);
tErrDelay1(IN := errorBeepTrigger, PT := T#0MS);
tErrDelay2(IN := errorBeepTrigger, PT := T#400MS);
tErrDelay3(IN := errorBeepTrigger, PT := T#800MS);

rTrigErr1(CLK := tErrDelay1.Q);
rTrigErr2(CLK := tErrDelay2.Q);
rTrigErr3(CLK := tErrDelay3.Q);

tpErr(IN := (rTrigErr1.Q OR rTrigErr2.Q OR rTrigErr3.Q), PT := T#200MS);

gBeeper := tpBeepTarget.Q OR tpErr.Q;

IF tErrTotal.Q THEN errorBeepTrigger := FALSE; END_IF;

(* Update Previous States *)
prev_d7 := btnD7;
prev_d8 := btnD8;
prev_both := both;
END_PROGRAM

(* @NESTEDCOMMENTS := 'Yes' *)
(* @PATH := '' *)
(* @OBJECTFLAGS := '0, 8' *)
TYPE COMSETTINGS_FALLBACK : STRUCT
    Port : INT; (* PORTS in library; INT used locally to avoid enum conflicts *)
    dwBaudRate : DWORD;
    byStopBits : BYTE;
    byParity : BYTE;
    dwTimeout : DWORD;
    dwBufferSize : DWORD;
    dwScan : DWORD;
END_STRUCT
END_TYPE

(* @END_DECLARATION := '0' *)

(* @NESTEDCOMMENTS := 'Yes' *)
(* @GLOBAL_VARIABLE_LIST := 'Global_Variables' *)
(* @PATH := '' *)
(* @OBJECTFLAGS := '0, 8' *)
(* @SYMFILEFLAGS := '2048' *)

VAR_GLOBAL RETAIN
    gTargetAngle : REAL := 45.0;
    gDefaultTarget : REAL := 45.0;
    gCurrentAngle : REAL := 0.0;
    gCycle : INT := 1;
    gEncoderCount : DINT := 0;
    gCalibCountsPerRev : DINT := 360;

    gCalibStatus : INT := 0;
    gCalibRevsDone : INT := 0;
    gCalibRevsTarget : INT := 3;
    gCalibMeasured : REAL := 0.0;

    (* Modbus / system variables and Modbus-mapped registers are defined by PLC_CONFIGURATION;
       do not redeclare `gModbus_Master_*`, `mb_out_*` or `mb_in_*` here to avoid duplicates. *)
    (* gDI and gDO variables are also typically defined in PLC_CONFIGURATION *)
END_VAR
(* @OBJECT_END := 'Global_Variables' *)
(* @CONNECTIONS := Global_Variables
FILENAME : ''
FILETIME : 0
EXPORT : 0
NUMOFCONNECTIONS : 0
*)

(* @NESTEDCOMMENTS := 'Yes' *)
(* @GLOBAL_VARIABLE_LIST := 'Variable_Configuration_1' *)
(* @PATH := '' *)
(* @OBJECTFLAGS := '0, 8' *)
(* @SYMFILEFLAGS := '2048' *)
VAR_CONFIG
END_VAR
(* @OBJECT_END := 'Variable_Configuration_1' *)
(* @CONNECTIONS := Variable_Configuration_1
FILENAME : ''
FILETIME : 0
EXPORT : 0
NUMOFCONNECTIONS : 0
*)

