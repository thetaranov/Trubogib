

(* @NESTEDCOMMENTS := 'Yes' *)
(* @PATH := '' *)
(* @OBJECTFLAGS := '0, 8' *)
(* @SYMFILEFLAGS := '2048' *)
PROGRAM PLC_PRG
VAR
    (* Ћогика режима и кнопок *)
    prev_d5 : BOOL := TRUE;
    enableStart : BOOL;      (* D5: 1-ручной, 0-авто *)
    btnD7 : BOOL;            (* D7: педаль вперед *)
    btnD8 : BOOL;            (* D8: педаль назад *)
    both : BOOL;             (* ќбе нажаты *)
    
    (* ƒетекторы фронтов *)
    encAEdge : R_TRIG;
    encBEdge : R_TRIG;
    
    (* —осто€ние цикла *)
    done : BOOL := FALSE;    (* ‘лаг завершени€ гиба *)
    
    (* “аймеры и сигналы *)
    targetPulseTrigger : BOOL := FALSE;
    tpTarget : TP;           (* »мпульс на DO12 *)
    beepTargetTrigger : BOOL := FALSE;
    tpBeepTarget : TP;       (* ѕиск при достижении цели *)
    
    errorBeepTrigger : BOOL := FALSE;
    tErrTotal : TON;
    tErrDelay1 : TON;
    tErrDelay2 : TON;
    tErrDelay3 : TON;
    rTrigErr1 : R_TRIG;
    rTrigErr2 : R_TRIG;
    rTrigErr3 : R_TRIG;
    tpErr : TP;

    (* ѕам€ть дл€ логики фронтов *)
    prev_d7 : BOOL := FALSE;
    prev_d8 : BOOL := FALSE;
    prev_both : BOOL := FALSE;

    (* Modbus переменные *)
    prev_mb_in_command : WORD := 0;
END_VAR
(* @END_DECLARATION := '0' *)
(* 1. „“≈Ќ»≈ ‘»«»„≈— »’ ¬’ќƒќ¬ *)
enableStart := gDI_5; 
btnD7 := gDI_7;       
btnD8 := gDI_8;       
both := btnD7 AND btnD8;

(* 2. ќЅ–јЅќ“ ј ЁЌ ќƒ≈–ј *)
encAEdge(CLK := gEncoderA);
encBEdge(CLK := gEncoderB);

IF encAEdge.Q THEN
    IF gEncoderB THEN
        gEncoderCount := gEncoderCount + 1;
    ELSE
        gEncoderCount := gEncoderCount - 1;
    END_IF;
END_IF;

(* 3. –ј—„≈“ “≈ ”ў≈√ќ ”√Ћј *)
IF (gCalibCountsPerRev = 0) THEN
    gCalibCountsPerRev := 360;
END_IF;
gCurrentAngle := - DINT_TO_REAL(gEncoderCount) * 360.0 / DINT_TO_REAL(gCalibCountsPerRev);

(* 4.  јЋ»Ѕ–ќ¬ ј ЌќЋя ѕ–» ѕ≈–≈’ќƒ≈ ¬ ј¬“ќ *)
IF (prev_d5 AND NOT enableStart) THEN
    gEncoderCount := 0;
    gCurrentAngle := 0.0;
    gCycle := 1;
    gTargetAngle := gDefaultTarget;
    done := FALSE;
END_IF;
prev_d5 := enableStart;

(* 5. ѕ–»≈ћ ƒјЌЌџ’ »« ¬≈Ѕј (ESP -> PLC) *)

(* „тение целевого угла (–егистр 10) *)
IF mb_in_WebTarget <> 0 THEN
    IF ABS(gTargetAngle - (WORD_TO_REAL(mb_in_WebTarget) / 10.0)) > 0.1 THEN
        gTargetAngle := WORD_TO_REAL(mb_in_WebTarget) / 10.0;
        gDefaultTarget := gTargetAngle; 
        done := FALSE; 
    END_IF;
END_IF;

(* „тение команд —тарт/—топ/Ќоль (–егистр 9) *)
IF mb_in_Command <> 0 AND mb_in_Command <> prev_mb_in_command THEN
    CASE WORD_TO_INT(mb_in_Command) OF
        1: (* —“ј–“ *)
            IF NOT enableStart THEN done := FALSE; gCycle := 1; END_IF;
        2: (* —“ќѕ *)
            done := TRUE; (* –ежим "—топ" - имитируем достижение цели *)
        3: (* ЌќЋ№ *)
            gEncoderCount := 0; gCurrentAngle := 0.0;
    END_CASE;
END_IF;
prev_mb_in_command := mb_in_Command;

(* 6. ¬џЅќ– ÷≈Ћ» ¬ «ј¬»—»ћќ—“» ќ“ ÷» Ћј (ј¬“ќ) *)
IF NOT enableStart AND NOT done THEN
    IF gCycle = 1 THEN
        gTargetAngle := gDefaultTarget;
    ELSIF gCycle = 2 THEN
        gTargetAngle := 0.0;
    END_IF;
END_IF;

(* 7. ќ“ѕ–ј¬ ј ƒјЌЌџ’ ¬ ¬≈Ѕ (PLC -> ESP) *)
mb_out_DefaultTarget := REAL_TO_WORD(gDefaultTarget * 10.0);
mb_out_CurrentAngle  := REAL_TO_WORD(ABS(gCurrentAngle * 10.0));
mb_out_TargetAngle   := REAL_TO_WORD(gTargetAngle * 10.0);
mb_out_Cycle         := INT_TO_WORD(gCycle);

IF done THEN mb_out_Done := 1; ELSE mb_out_Done := 0; END_IF;
IF enableStart THEN mb_out_Mode := 1; ELSE mb_out_Mode := 0; END_IF;

mb_out_Pedals := 0;
IF btnD7 THEN mb_out_Pedals := mb_out_Pedals + 1; END_IF;
IF btnD8 THEN mb_out_Pedals := mb_out_Pedals + 2; END_IF;

(* 8. Ћќ√» ј ”ѕ–ј¬Ћ≈Ќ»я ћќ“ќ–ќћ *)
IF enableStart THEN  (* –учной режим *)
    gDO_10 := btnD7 AND NOT btnD8 AND NOT both;
    gDO_11 := btnD8 AND NOT btnD7 AND NOT both;
ELSE  (* јвто режим *)
    gDO_10 := btnD7 AND NOT btnD8 AND (gCurrentAngle < gTargetAngle) AND NOT done;
    gDO_11 := btnD8 AND NOT btnD7 AND (gCurrentAngle > 0.0) AND NOT done;
END_IF;

(* 9. ј¬“ќћј“»„≈— »… ќ—“јЌќ¬ *)
IF NOT enableStart AND NOT done THEN
    IF (ABS(gCurrentAngle - gTargetAngle) < 0.5) THEN
        done := TRUE;
        targetPulseTrigger := TRUE;
        beepTargetTrigger := TRUE;
        IF gCycle = 1 THEN gCycle := 2; ELSE gCycle := 1; END_IF;
    END_IF;
END_IF;

(* ≈сли вручную или через веб угол ушел от цели - сбрасываем Done *)
IF (ABS(gCurrentAngle - gTargetAngle) > 2.0) THEN
    done := FALSE;
END_IF;

(* 10. ќЅ–јЅќ“ ј “ј…ћ≈–ќ¬ » —»√ЌјЋќ¬ (»—ѕ–ј¬Ћ≈Ќќ) *)
tpTarget(IN := targetPulseTrigger, PT := T#500MS);
gDO_12 := tpTarget.Q;
IF tpTarget.Q THEN targetPulseTrigger := FALSE; END_IF;

tpBeepTarget(IN := beepTargetTrigger, PT := T#500MS);
(* —игнал ошибки *)
IF NOT enableStart AND NOT done THEN
    IF ((btnD7 AND NOT prev_d7) AND (gCurrentAngle >= gDefaultTarget)) OR
       ((btnD8 AND NOT prev_d8) AND (gCurrentAngle <= 0.0)) OR
       (both AND NOT prev_both) THEN
        errorBeepTrigger := TRUE;
    END_IF;
END_IF;

tErrTotal(IN := errorBeepTrigger, PT := T#1400MS);
tErrDelay1(IN := errorBeepTrigger, PT := T#0MS);
tErrDelay2(IN := errorBeepTrigger, PT := T#400MS);
tErrDelay3(IN := errorBeepTrigger, PT := T#800MS);
rTrigErr1(CLK := tErrDelay1.Q);
rTrigErr2(CLK := tErrDelay2.Q);
rTrigErr3(CLK := tErrDelay3.Q);
tpErr(IN := (rTrigErr1.Q OR rTrigErr2.Q OR rTrigErr3.Q), PT := T#200MS);

gBeeper := tpBeepTarget.Q OR tpErr.Q;

IF tErrTotal.Q THEN errorBeepTrigger := FALSE; END_IF;

prev_d7 := btnD7;
prev_d8 := btnD8;
prev_both := both;
END_PROGRAM

(* @NESTEDCOMMENTS := 'Yes' *)
(* @PATH := '' *)
(* @OBJECTFLAGS := '0, 8' *)
TYPE COMSETTINGS_FALLBACK : STRUCT
    Port : INT; (* PORTS in library; INT used locally to avoid enum conflicts *)
    dwBaudRate : DWORD;
    byStopBits : BYTE;
    byParity : BYTE;
    dwTimeout : DWORD;
    dwBufferSize : DWORD;
    dwScan : DWORD;
END_STRUCT
END_TYPE

(* @END_DECLARATION := '0' *)

(* @NESTEDCOMMENTS := 'Yes' *)
(* @GLOBAL_VARIABLE_LIST := 'Global_Variables' *)
(* @PATH := '' *)
(* @OBJECTFLAGS := '0, 8' *)
(* @SYMFILEFLAGS := '2048' *)
VAR_GLOBAL RETAIN
    (* Inputs *)
    gDI_1   AT %IX0.0   : BOOL; (* Fast Input 1 *)
    gDI_2   AT %IX0.1   : BOOL; (* Fast Input 2 *)
    gDI_3   AT %IX1.0.0 : BOOL; (* Input 3 *)
    gDI_4   AT %IX1.0.1 : BOOL; (* Input 4 *)
    gDI_5   AT %IX1.0.2 : BOOL; (* Input 5 *)
    gDI_6   AT %IX1.0.3 : BOOL; (* Input 6 *)
    gDI_7   AT %IX1.0.4 : BOOL; (* Input 7 *)
    gDI_8   AT %IX1.0.5 : BOOL; (* Input 8 *)
    gDI_9   AT %IX1.0.6 : BOOL; (* Input 9 *)
    gDI_10  AT %IX1.0.7 : BOOL; (* Input 10 *)
    gDI_11  AT %IX1.1.0 : BOOL; (* Input 11 *)
    gDI_12  AT %IX1.1.1 : BOOL; (* Input 12 *)
    gDI_13  AT %IX1.1.2 : BOOL; (* Input 13 *)
    gDI_14  AT %IX1.1.3 : BOOL; (* Input 14 *)
    gDI_15  AT %IX1.1.4 : BOOL; (* Input 15 *)
    gDI_16  AT %IX1.1.5 : BOOL; (* Input 16 *)
    gDI_17  AT %IX1.1.6 : BOOL; (* Input 17 *)
    gDI_18  AT %IX1.1.7 : BOOL; (* Input 18 *)

    (* Fast encoder inputs (alias to fast inputs) - keep names used by code *)
    gEncoderA AT %IX0.0 : BOOL;  (* Encoder A (fast input) *)
    gEncoderB AT %IX0.1 : BOOL;  (* Encoder B (fast input) *)

    (* Outputs *)
    gDO_1   AT %QX2.0   : BOOL; (* Fast Output 1 *)
    gDO_2   AT %QX2.1   : BOOL; (* Fast Output 2 *)
    gDO_3   AT %QX2.2   : BOOL; (* Fast Output 3 *)
    gDO_4   AT %QX2.3   : BOOL; (* Fast Output 4 *)

    gDO_5   AT %QX3.0.0 : BOOL; (* Relay/Slow Output 5 *)
    gDO_6   AT %QX3.0.1 : BOOL; (* Relay/Slow Output 6 *)
    gDO_7   AT %QX3.0.2 : BOOL; (* Relay/Slow Output 7 *)
    gDO_8   AT %QX3.0.3 : BOOL; (* Relay/Slow Output 8 *)
    gDO_9   AT %QX3.0.4 : BOOL; (* Relay/Slow Output 9 *)
    gDO_10  AT %QX3.0.5 : BOOL; (* Relay/Slow Output 10 *)
    gDO_11  AT %QX3.0.6 : BOOL; (* Relay/Slow Output 11 *)
    gDO_12  AT %QX3.0.7 : BOOL; (* Relay/Slow Output 12 *)

    (* System outputs *)
    gBeeper AT %QX5.0   : BOOL; (* External beeper output *)

    (* ModBus (Master) system/channel variables exposed by device configuration *)
    gModbus_Master_Channel AT %QD6.0 : DWORD; (* ModBus Master: channel/last address (Q area) *)
    gModbus_Master_LastError AT %QW6.1 : WORD; (* ModBus Master: last error code (Q area) *)

    (* Variables for Modbus and internal state (no AT) *)
    gTargetAngle : REAL := 45.0;    (* target angle, degrees *)
    gDefaultTarget : REAL := 45.0;  (* retained default target; used to toggle between endpoints *)
    gCurrentAngle : REAL := 0.0;    (* current angle, degrees *)
    gCycle : INT := 1;              (* 1=to default, 2=to zero *)
    gAngleFromStart : REAL := 0.0;  (* angle from program start *)
    gStatus : INT := 0;             (* 0=Stop,1=Moving,2=In position *)
    gErrorCode : INT := 0;          (* 0=OK,1=Timeout,2=Fault *)
    gCommand : INT := 0;            (* 1=Start,2=Stop,3=Calibrate *)
    gEncoderCount : DINT := 0;     (* encoder counter for Modbus *)

    (* Calibration / Modbus helper variables *)
    gStartCalib : BOOL := FALSE;
    gCalibRunning : BOOL := FALSE;
    gCalibStatus : INT := 0;
    gCalibRevsDone : INT := 0;
    gCalibRevsTarget : INT := 3;
    gCalibMeasured : REAL := 0.0;
    gCalibCountsPerRev : DINT := 0;
    (* Modbus mapped variables are provided by device configuration channels *)
END_VAR
(* @OBJECT_END := 'Global_Variables' *)
(* @CONNECTIONS := Global_Variables
FILENAME : ''
FILETIME : 0
EXPORT : 0
NUMOFCONNECTIONS : 0
*)

