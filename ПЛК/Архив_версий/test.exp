

(* @NESTEDCOMMENTS := 'Yes' *)
(* @PATH := '' *)
(* @OBJECTFLAGS := '0, 8' *)
(* @SYMFILEFLAGS := '2048' *)
PROGRAM PLC_PRG
VAR
    enableStart : BOOL; (* D5 - Enable *)
    btnD7 : BOOL;       (* D7 - Button *)
    btnD8 : BOOL;       (* D8 - Reverse Button *)
    enableEdge : R_TRIG; (* rising edge detector for enable *)
    startEdge : R_TRIG; (* rising edge detector for start button *)
    startEdgeD8 : R_TRIG; (* rising edge detector for reverse button *)
    encAEdge : R_TRIG;  (* encoder A rising edge detector *)
    encBEdge : R_TRIG;  (* encoder B rising edge detector *)
    resetBtn : BOOL;    (* reset button local read *)
    resetEdgeBtn : R_TRIG; (* rising edge detector for reset button *)

    (* Beeper timers/FBs for 3 short beeps over 2s *)
    gBeepStart : BOOL; (* start beeper sequence flag, local control *)
    tBeepTotal : TON;  (* total beeper duration *)
    tBeepDelay1 : TON; (* beep 1 delay (0ms) *)
    tBeepDelay2 : TON; (* beep 2 delay (600ms) *)
    tBeepDelay3 : TON; (* beep 3 delay (1200ms) *)
    rTrigBeep1 : R_TRIG;
    rTrigBeep2 : R_TRIG;
    rTrigBeep3 : R_TRIG;
    tpBeep : TP;       (* pulse timer to generate short beep *)
    tpTrigger : BOOL;  (* internal trigger for TP *)
    (* Error beeper: 6 short pulses (150ms) *)
    errorBeepStart : BOOL;
    tErrTotal : TON;
    tErrDelay1 : TON;
    tErrDelay2 : TON;
    tErrDelay3 : TON;
    tErrDelay4 : TON;
    tErrDelay5 : TON;
    tErrDelay6 : TON;
    rTrigErr1 : R_TRIG;
    rTrigErr2 : R_TRIG;
    rTrigErr3 : R_TRIG;
    rTrigErr4 : R_TRIG;
    rTrigErr5 : R_TRIG;
    rTrigErr6 : R_TRIG;
    tpErr : TP;
    arrivedTargetSignalled : BOOL;
    arrivedHomeSignalled : BOOL;
    (* Start-timeout / alarm logic *)
    startTimeoutActive : BOOL;
    tStartTimeout : TON;    (* 2s timer to detect no movement after pedal press *)
    errorLock : BOOL;       (* when TRUE, outputs disabled until reset *)
    (* desiredMove: 1 = forward, -1 = reverse, 0 = none *)
    desiredMove : INT;
    encDelta : INT;         (* +1/-1 from encoder edge direction *)
    (* DO9 alarm pulse and enable (D5) long beep *)
    do9PulseTrigger : BOOL;
    tpDO9 : TP;
    tpEnable : TP;
    blockedPedal : INT;    (* 0=none, 7=forward pedal blocked, 8=reverse pedal blocked *)
    prevEnableStart : BOOL; (* previous scan state of D5 for falling-edge detection *)
    manualModeLocal : BOOL;
    (* local cycle debug / runtime indicator handled in globals too *)
END_VAR

(* @END_DECLARATION := '0' *)
(* Read inputs *)
enableStart := gDI_5; (* D5 used as manual mode switch *)
(* manualMode TRUE = D5 pressed = manual mode (free rotation). FALSE = normal mode with limits *)
manualModeLocal := enableStart;
btnD7 := gDI_7;
btnD8 := gDI_8;

(* Detect falling edge of D5 (manual -> normal): when prevEnableStart was TRUE and now FALSE *)
IF (prevEnableStart AND NOT enableStart) THEN
    (* manual turned OFF -> reset angle and start normal cycle 1 immediately *)
    gCurrentAngle := 0.0;
    gEncoderCount := 0;
    gCycle := 1;
    gTargetAngle := gDefaultTarget;
    gDO_10 := FALSE;
    gDO_11 := FALSE;
    gDO_12 := FALSE;
    gStatus := 0;
END_IF;

(* Edge detectors *)
enableEdge(CLK := enableStart);
startEdge(CLK := btnD7);
startEdgeD8(CLK := btnD8);
encAEdge(CLK := gEncoderA);
encBEdge(CLK := gEncoderB);

(* Set `gTargetAngle` according to `gCycle` rule:
   - gCycle = 1 -> use `gDefaultTarget` (e.g., 45°)
   - gCycle = 2 -> use 0.0 (home)
   - otherwise -> use `gDefaultTarget`
   This enforces the user's rule deterministically each scan. *)
IF NOT manualModeLocal THEN
    IF gCycle = 1 THEN
        gTargetAngle := gDefaultTarget;
    ELSIF gCycle = 2 THEN
        gTargetAngle := 0.0;
    ELSE
        gTargetAngle := gDefaultTarget;
    END_IF;
END_IF;

(* On system enable rising edge: clear latched alarms and reset outputs (do not reset encoder/angle) *)
(* On enable rising edge: manual mode entered. Do not reset encoder/angle here.
    Reset on manual->normal transition (falling edge) is handled separately. *)

(* Encoder counting (count on rising edge of A; direction by B); adjust direction later if inverted *)
IF encAEdge.Q THEN
    IF gEncoderB THEN
        encDelta := 1;
        gEncoderCount := gEncoderCount + 1;
    ELSE
        encDelta := -1;
        gEncoderCount := gEncoderCount - 1;
    END_IF;
    (* Cancel start-timeout only if motion is toward desiredMove *)
    IF (startTimeoutActive) AND (desiredMove <> 0) THEN
        IF (encDelta = desiredMove) THEN
            startTimeoutActive := FALSE;
            desiredMove := 0; (* movement detected toward target - disarm *)
        END_IF;
    END_IF;
END_IF;

(* Ensure counts-per-rev is valid and compute current angle from encoder count *)
IF (gCalibCountsPerRev = 0) THEN
    gCalibCountsPerRev := 360; (* default PPR *)
END_IF;

(* Calculate current angle from encoder count. Inverted sign to change rotation direction *)
gCurrentAngle := - DINT_TO_REAL(gEncoderCount) * 360.0 / DINT_TO_REAL(gCalibCountsPerRev);



(* Start bending only when enabled and start button pressed (rising edge) *)
(* Hold-to-run logic: outputs only active while pedal held, enable pressed,
   and within allowed range. Also prevent both pedals operating simultaneously. *)
(* Forward DO10: allowed only when enable pressed, forward pedal pressed, reverse pedal NOT pressed,
   and current angle is strictly less than target (so it won't start at target). *)
(* In manual mode allow free rotation both directions (no angle limits).
    In normal mode enforce angle limits to prevent moving past endpoints. *)
IF manualModeLocal THEN
    (* Manual mode: allow each pedal to directly control its output without blocking the other *)
    gDO_10 := enableStart AND btnD7;
    gDO_11 := enableStart AND btnD8;
ELSE
    (* Normal mode: D5 is false. Drive outputs based on pedals and angle limits (no D5 enable required). *)
    gDO_10 := btnD7 AND (gCurrentAngle < gTargetAngle);  (* forward only if below target *)
    gDO_11 := btnD8 AND (gCurrentAngle > 0.0);           (* reverse only if above zero *)
END_IF;

(* Update movement status: 1 = moving, 0 = stopped, 2 = in-position *)
IF (gDO_10 OR gDO_11) THEN
    gStatus := 1;
ELSIF gDO_12 THEN
    gStatus := 2;
ELSE
    gStatus := 0;
END_IF;

(* When running, check if target reached: switch off motor (DO10) and turn on in-position (DO12) *)
(* While moving forward, stop exactly at target and signal arrival. Motor must not run beyond target. *)
IF NOT manualModeLocal THEN
    IF (gStatus = 1) AND (gDO_10) THEN
        IF (gCurrentAngle >= gTargetAngle) THEN
            gDO_10 := FALSE;
            gDO_12 := TRUE;
            gStatus := 2;    (* 2 = In position *)
            gCycle := 2;     (* 2 = At target *)
            IF NOT arrivedTargetSignalled THEN
                gBeepStart := TRUE; (* normal arrival beeper, only once per arrival *)
                arrivedTargetSignalled := TRUE;
                (* Arrival: set cycle to At-target; `gTargetAngle` mapping will switch target to 0.0 next scan. *)
                arrivedHomeSignalled := FALSE; (* allow home arrival signalling later *)
                (* In normal mode, pulse DO9 for 1s to indicate successful arrival *)
                do9PulseTrigger := TRUE;
            END_IF;
        END_IF;
    END_IF;
END_IF;

(* Reverse start: handle on rising edge of D8 (like forward). If at home (0.0) -> error beep; else start reverse cycle. *)
(* legacy edge-start block removed: hold-to-run logic controls DO11 directly *)

(* Reverse arrival: while moving reverse (gDO_11 active), stop at 0°, zero encoder and switch to cycle 1 (0->default). *)
IF NOT manualModeLocal THEN
    IF (gStatus = 1) AND (gDO_11) THEN
        IF (gCurrentAngle <= 0.0) THEN
            gDO_11 := FALSE;
            gStatus := 0;                 (* 0 = Stop at home *)
            gEncoderCount := 0;
            gCurrentAngle := 0.0;
            IF NOT arrivedHomeSignalled THEN
                gBeepStart := TRUE;       (* signal arrival at 0° with normal beeper, once *)
                arrivedHomeSignalled := TRUE;
                gCycle := 1; (* Home -> next cycle is 1: 0 -> gDefaultTarget *)
                arrivedTargetSignalled := FALSE; (* allow forward arrival signalling later *)
            END_IF;
        END_IF;
    END_IF;
END_IF;

    (* clear desiredMove and timeout when reverse pedal released *)
    IF NOT btnD8 THEN
            gDO_11 := FALSE; (* stop reverse motor when reverse pedal released *)
            desiredMove := 0;
            startTimeoutActive := FALSE;
            IF gStatus = 1 THEN
                gStatus := 0;
            END_IF;
    END_IF;

(* Remove continuous-held error triggers; use rising-edge checks only. *)

(* Reset arrival latches when moving away from limits *)
IF (gCurrentAngle < gTargetAngle) THEN
    arrivedTargetSignalled := FALSE;
END_IF;
IF (gCurrentAngle > 0.0) THEN
    arrivedHomeSignalled := FALSE;
END_IF;

(* If in normal mode and we've reached (or passed) the target but didn't arrive via motion,
   signal the 1s DO9 pulse once. This covers cases where `gCurrentAngle` is set externally. *)
IF NOT manualModeLocal THEN
    IF (gCurrentAngle >= gTargetAngle) AND (NOT arrivedTargetSignalled) THEN
        do9PulseTrigger := TRUE;
        arrivedTargetSignalled := TRUE;
    END_IF;
END_IF;

(* Start timeout timer/timeout alarm disabled while working in simplified 2-cycle mode. *)
(* tStartTimeout(IN := startTimeoutActive, PT := T#2S);
IF tStartTimeout.Q AND startTimeoutActive THEN
    do9PulseTrigger := TRUE; (* start DO9 TP *)
    errorLock := TRUE;    (* latch error until reset *)
    gDO_10 := FALSE;      (* ensure motors are off *)
    gDO_11 := FALSE;
    startTimeoutActive := FALSE;
    desiredMove := 0;
    errorBeepStart := TRUE; (* give audible alarm pattern too *)
END_IF; *)

(* Reset handled on `D5` rising edge (enableEdge) to clear latched alarm and error beeps.) *)

(* DO9 pulse TP and enable long-beep TP disabled for simplified mode *)
(* DO9 pulse TP: 1s pulse on successful arrival in normal mode *)
tpDO9(IN := do9PulseTrigger, PT := T#1S);
gDO_9 := tpDO9.Q; (* DO9 is driven by TP for 1s pulse *)
IF tpDO9.Q THEN
    do9PulseTrigger := FALSE;
END_IF;

(* Only drive DO9 and beeper for blocked-pedal alarms while that pedal remains pressed. *)
IF blockedPedal = 7 THEN
    (* forward pedal is the blocked one; only keep alarm while forward pedal is pressed *)
    IF NOT btnD7 THEN
        blockedPedal := 0; (* clear when pedal released *)
    END_IF;
ELSIF blockedPedal = 8 THEN
    IF NOT btnD8 THEN
        blockedPedal := 0;
    END_IF;
END_IF;

(* Long enable beep on rising edge of enable (D5) for 2s) disabled temporarily *)
(* tpEnable(IN := enableEdge.Q, PT := T#2S); *)

(* Reset button handling: `gDI_11` resets alarm latch only (does not change stored angle or gCycle) *)
resetBtn := gDI_11;
resetEdgeBtn(CLK := resetBtn);
IF resetEdgeBtn.Q THEN
    errorLock := FALSE;      (* clear hard alarm latch *)
    errorBeepStart := FALSE; (* stop error beeper *)
    do9PulseTrigger := FALSE;(* stop DO9 pulse if active *)
    blockedPedal := 0;       (* clear any blocked pedal on reset *)
END_IF;

(* Save previous enable state for falling-edge detection next scan *)
prevEnableStart := enableStart;


(* Beeper sequence control: three short pulses (200ms) at 0ms, 600ms and 1200ms within a 2s window *)
tBeepTotal(IN := gBeepStart, PT := T#2S);
tBeepDelay1(IN := gBeepStart, PT := T#0MS);
tBeepDelay2(IN := gBeepStart, PT := T#600MS);
tBeepDelay3(IN := gBeepStart, PT := T#1200MS);
rTrigBeep1(CLK := tBeepDelay1.Q);
rTrigBeep2(CLK := tBeepDelay2.Q);
rTrigBeep3(CLK := tBeepDelay3.Q);
tpBeep(IN := (rTrigBeep1.Q OR rTrigBeep2.Q OR rTrigBeep3.Q), PT := T#200MS);
(* Normal beeper output *)

(* Error beeper sequence: six short pulses 150ms spaced by 150ms over ~1.8s *)
tErrTotal(IN := errorBeepStart, PT := T#1800MS);
tErrDelay1(IN := errorBeepStart, PT := T#0MS);
tErrDelay2(IN := errorBeepStart, PT := T#300MS);
tErrDelay3(IN := errorBeepStart, PT := T#600MS);
tErrDelay4(IN := errorBeepStart, PT := T#900MS);
tErrDelay5(IN := errorBeepStart, PT := T#1200MS);
tErrDelay6(IN := errorBeepStart, PT := T#1500MS);
rTrigErr1(CLK := tErrDelay1.Q);
rTrigErr2(CLK := tErrDelay2.Q);
rTrigErr3(CLK := tErrDelay3.Q);
rTrigErr4(CLK := tErrDelay4.Q);
rTrigErr5(CLK := tErrDelay5.Q);
rTrigErr6(CLK := tErrDelay6.Q);
tpErr(IN := (rTrigErr1.Q OR rTrigErr2.Q OR rTrigErr3.Q OR rTrigErr4.Q OR rTrigErr5.Q OR rTrigErr6.Q), PT := T#150MS);

(* Combine beepers: error beeper overrides normal beeper if active; include enable long-beep *)
gBeeper := tpErr.Q OR tpBeep.Q OR tpEnable.Q;
IF tBeepTotal.Q THEN
    gBeepStart := FALSE;
END_IF;
IF tErrTotal.Q THEN
    errorBeepStart := FALSE;
END_IF;

(* System-disable gating based on `D5` removed because `D5` is used as manual-mode switch.
   If you need a separate global system-enable input, restore checks here using that input. *)
END_PROGRAM

(* @NESTEDCOMMENTS := 'Yes' *)
(* @PATH := '' *)
(* @OBJECTFLAGS := '0, 8' *)
TYPE COMSETTINGS_FALLBACK : STRUCT
    Port : INT; (* PORTS in library; INT used locally to avoid enum conflicts *)
    dwBaudRate : DWORD;
    byStopBits : BYTE;
    byParity : BYTE;
    dwTimeout : DWORD;
    dwBufferSize : DWORD;
    dwScan : DWORD;
END_STRUCT
END_TYPE

